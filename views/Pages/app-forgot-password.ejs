<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,viewport-fit=cover"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="theme-color" content="#FAFAF8"/>
  <title>Dhaga.Thread — Reset Password</title>
  <meta name="description" content="Reset your password on Dhaga.Thread."/>
  <link rel="icon" type="image/png" href="../assets/img/favicon.png" sizes="32x32"/>
  <link rel="stylesheet" href="../assets/css/src/bootstrap/bootstrap.min.css"/>
  <link rel="stylesheet" href="../assets/css/serif.css"/>
  <link rel="manifest" href="../__manifest.json"/>
</head>
<body>
<div class="s-glow"></div>

<div class="s-auth-page">

  <!-- Brand -->
  <div class="s-auth-brand">
    <h1>Dhaga.Thread</h1>
    <p>From Farm to Fabric</p>
  </div>

  <!-- Card -->
  <div class="s-auth-card">

    <!-- Section label -->
    <div class="s-section-label" style="margin-bottom:20px;">
      <span class="line"></span>
      <span class="text">Reset</span>
      <span class="line"></span>
    </div>

    <h2 class="s-auth-title">Forgot password?</h2>
    <p class="s-auth-subtitle">Enter your email address and we'll send you instructions to reset your password.</p>

    <form action="../Pages/app-login.html" method="get" id="resetForm">

      <div class="s-field">
        <label for="email1">E-mail address</label>
        <input type="email" id="email1" name="email" placeholder="your@email.com" autocomplete="email" required/>
      </div>

      <button type="submit" class="s-btn-primary" id="resetBtn">Reset Password</button>

    </form>

    <div class="s-auth-links" style="justify-content: center; gap: 8px;">
      <span style="font-family: var(--s-font-sans); font-size: 0.85rem; color: var(--s-muted-fg);">Remember your password?</span>
      <a href="../Pages/app-login.html" style="color: var(--s-accent); font-weight: 500;">Sign In</a>
    </div>

  </div>

  <!-- Footer note -->
  <p style="margin-top:32px;font-family:var(--s-font-mono);font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--s-muted-fg);text-align:center;">
    Ministry of Textiles, Government of India
  </p>

</div>

<script src="../assets/js/lib/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
<script src="../assets/js/base.js"></script>
<script>
  document.getElementById('resetForm').addEventListener('submit', function() {
    var b = document.getElementById('resetBtn');
    b.textContent = 'Sending reset link…';
    b.style.opacity = '0.7';
  });
</script>
</body>
</html>
