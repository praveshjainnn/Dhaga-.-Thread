      <ul class="s-services-list mb-4">
        <li>
          <a href="/Services/shearing-service" class="s-service-item">
            <div class="s-service-icon">✂️</div>
            <span><%= translation.ShearingServices %></span>
            <ion-icon name="chevron-forward-outline" class="s-service-arrow"></ion-icon>
          </a>
        </li>
        <li>
          <a href="/Services/sorting-service" class="s-service-item">
            <div class="s-service-icon">🗂️</div>
