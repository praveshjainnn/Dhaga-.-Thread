<!-- Scripts to dynamically set active page and user cookies -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 1. Auto-highlight active navigation tabs
        var path = window.location.pathname.toLowerCase();
        if (path.indexOf('/woolkart') !== -1) {
            document.getElementById('nav-woolkart').classList.add('active');
        } else if (path.indexOf('/learning') !== -1) {
            document.getElementById('nav-learning').classList.add('active');
        } else if (path.indexOf('/services') !== -1) {
            document.getElementById('nav-services').classList.add('active');
        } else if (path.indexOf('/statistics') !== -1) {
            document.getElementById('nav-statistics').classList.add('active');
        } else {
            // default to overview if on home/farmer/seller etc.
            document.getElementById('nav-overview').classList.add('active');
        }

        // 2. Populate sidebar profile using cookies if present
        function getCookieVal(name) {
            var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            if (match) return decodeURIComponent(match[2]);
            return null;
        }

        var userName = getCookieVal('userID') ? 'Demo User' : 'Guest';
        var userRole = getCookieVal('role') || 'User';

        try {
            var userCookie = getCookieVal('user');
            if (userCookie) {
                var userData = JSON.parse(userCookie);
                if (userData.name) userName = userData.name;
                if (userData.role) userRole = userData.role;
            }
        } catch (e) {
            console.error("Error reading user cookie", e);
        }

        var sidebarNameEl = document.getElementById('sidebarUserName');
        var sidebarRoleEl = document.getElementById('sidebarUserRole');
        if (sidebarNameEl) sidebarNameEl.textContent = userName;
        if (sidebarRoleEl) sidebarRoleEl.textContent = '🌾 ' + userRole;
    });

    function logout() {
        document.cookie = "token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
        document.cookie = "role=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
        document.cookie = "user=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
        window.location.href = "/Pages/app-login.html";
    }

    function openSidebar() {
        var modal = new bootstrap.Modal(document.getElementById('sidebarPanel'));
        modal.show();
    }
</script>
