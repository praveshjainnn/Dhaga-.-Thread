<!DOCTYPE html>
<html lang="en">
<%- include('../partials/serif-head', { title: 'KnitKraft — Profile Settings' }) %>
<body>
  <div class="s-glow"></div>

  <!-- Shared Header -->
  <%- include('../partials/serif-header', { showBack: true }) %>

  <!-- Main Content Page Area -->
  <main class="s-page" style="padding-bottom: 90px;">

    <!-- Section Heading -->
    <div class="s-section-heading">
      <h3>Profile Settings</h3>
      <p style="font-family: var(--s-font-sans); font-size: 0.88rem; color: var(--s-muted-fg); margin: 0 0 6px;">Manage your account credentials, role details, and address configurations.</p>
      <span class="s-rule-accent"></span>
    </div>

    <!-- Profile Summary Card -->
    <div class="card mb-4 text-center p-4">
      <img class="s-avatar mx-auto mb-3" src="/assets/img/sample/avatar/avatar1.jpg" alt="Profile" style="width: 100px; height: 100px; border-width: 2px;"/>
      <h4 id="profileName" style="margin: 0; font-family: var(--s-font-serif);">Demo User</h4>
      <div id="profileRole" style="font-family: var(--s-font-mono); font-size: 0.72rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--s-accent); margin-top: 4px;">User Role</div>
    </div>

    <!-- Settings Form -->
    <div class="card mb-4">
      <div class="card-body">
        <form id="profileForm">
          
          <div class="s-field">
            <label for="nameInput">Full Name</label>
            <input type="text" id="nameInput" placeholder="Enter full name"/>
          </div>

          <div class="s-field">
            <label for="emailInput">Email Address</label>
            <input type="email" id="emailInput" placeholder="enter email id"/>
          </div>

          <div class="s-field">
            <label for="phoneInput">Mobile Number</label>
            <input type="text" id="phoneInput" placeholder="enter phone number"/>
          </div>

          <div class="s-field">
            <label for="addressInput">Address Line 1</label>
            <input type="text" id="addressInput" placeholder="enter address line 1"/>
          </div>

          <div class="s-field">
            <label for="stateInput">State / Region</label>
            <input type="text" id="stateInput" placeholder="enter state"/>
          </div>

          <div class="s-field">
            <label for="countryInput">Country</label>
            <input type="text" id="countryInput" value="India" readonly style="background: var(--s-muted); color: var(--s-muted-fg);"/>
          </div>

          <button type="button" class="s-btn-primary w-100" onclick="saveProfile()">Save Settings</button>

        </form>
      </div>
    </div>

  </main>

  <!-- Shared Bottom Nav & Sidebar Modal -->
  <%- include('../partials/serif-nav') %>

  <!-- ══════════════════════════════════════════════════════
       JS FILES
  ══════════════════════════════════════════════════════ -->
  <script src="/assets/js/lib/bootstrap.bundle.min.js"></script>
  <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="/assets/js/base.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      // Load info from cookies
      function getCookieVal(name) {
        var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        if (match) return decodeURIComponent(match[2]);
        return null;
      }

      var name = "Demo User";
      var role = "User";
      var email = "demo@demo.com";

      try {
        var userCookie = getCookieVal('user');
        if (userCookie) {
          var userData = JSON.parse(userCookie);
          if (userData.name) name = userData.name;
          if (userData.role) role = userData.role;
          if (userData.email) email = userData.email;
        }
      } catch (e) {
        console.error(e);
      }

      document.getElementById('profileName').textContent = name;
      document.getElementById('profileRole').textContent = '🌾 ' + role;
      document.getElementById('nameInput').value = name;
      document.getElementById('emailInput').value = email;
    });

    function saveProfile() {
      alert("Settings saved successfully.");
    }
  </script>
</body>
</html>